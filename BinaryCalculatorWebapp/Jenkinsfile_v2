pipeline {
    agent {
        kubernetes {
            label 'sample-app'
            yaml """
apiVersion: v1
kind: Pod
metadata:
  labels:
    component: ci
spec:
  containers:
    - name: gcloud
      image: google/cloud-sdk:latest
      command:
        - cat
      tty: true
"""
        }
    }

    tools {
        maven 'maven'
    }

    environment {
        APP_NAME = 'binarycalculatorwebapp'
    }

    stages {
        stage('test') {
            steps {
                sh 'mvn clean test -f ./BinaryCalculatorWebapp/pom.xml'
            }
        }

        stage('build') {
            steps {
                sh 'mvn clean package -DskipTests -f ./BinaryCalculatorWebapp/pom.xml'
            }
        }

        stage('containerize') {
            steps {
                container('gcloud') {
                    withCredentials([
                        file(credentialsId: 'service_account', variable: 'SERVICE_ACCOUNT'),
                        string(credentialsId: 'project_id', variable: 'PROJECT'),
                        string(credentialsId: 'repo_path', variable: 'REPO_PATH')
                    ]) {
                        dir('BinaryCalculatorWebapp') {
                            sh '''
                                cat "$SERVICE_ACCOUNT" | head
                                gcloud auth activate-service-account --key-file="$SERVICE_ACCOUNT"
                                gcloud auth list
                                gcloud config set project "$PROJECT"
                                gcloud builds submit --tag "$REPO_PATH/$APP_NAME" --suppress-logs .
                            '''
                        }
                    }
                }
            }
        }

        stage('deployment') {
            steps {
                container('gcloud') {
                    withCredentials([
                        file(credentialsId: 'service_account', variable: 'SERVICE_ACCOUNT'),
                        string(credentialsId: 'project_id', variable: 'PROJECT'),
                        string(credentialsId: 'repo_path', variable: 'REPO_PATH'),
                        string(credentialsId: 'cluster_name', variable: 'CLUSTER'),
                        string(credentialsId: 'cluster_zone', variable: 'CLUSTER_ZONE')
                    ]) {
                        dir('BinaryCalculatorWebapp') {
                            sh '''
                                gcloud auth activate-service-account --key-file="$SERVICE_ACCOUNT"
                                gcloud config set project "$PROJECT"
                                gcloud container clusters get-credentials "$CLUSTER" --zone "$CLUSTER_ZONE"
                                kubectl delete deployment binarycalculator-deployment --ignore-not-found=true
                                kubectl create deployment binarycalculator-deployment --image="$REPO_PATH/$APP_NAME" --port=8080
                            '''
                        }
                    }
                }
            }
        }

        stage('service') {
            steps {
                container('gcloud') {
                    withCredentials([
                        file(credentialsId: 'service_account', variable: 'SERVICE_ACCOUNT'),
                        string(credentialsId: 'project_id', variable: 'PROJECT'),
                        string(credentialsId: 'cluster_name', variable: 'CLUSTER'),
                        string(credentialsId: 'cluster_zone', variable: 'CLUSTER_ZONE')
                    ]) {
                        dir('BinaryCalculatorWebapp') {
                            sh '''
                                gcloud auth activate-service-account --key-file="$SERVICE_ACCOUNT"
                                gcloud config set project "$PROJECT"
                                gcloud container clusters get-credentials "$CLUSTER" --zone "$CLUSTER_ZONE"
                                kubectl expose deployment binarycalculator-deployment --type=LoadBalancer --name=binarycalculator-service || true
                                kubectl get service binarycalculator-service
                            '''
                        }
                    }
                }
            }
        }
    }
}
